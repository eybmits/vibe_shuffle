SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Preferred fallback when Spotify Audio Features are unavailable:
SPOTIFY_CATALOG_MODE=curated
SPOTIFY_HAPPY_PLAYLIST_URL=
SPOTIFY_SAD_PLAYLIST_URL=

# Optional four-quadrant curated sources:
SPOTIFY_RELAXED_PLAYLIST_URL=
SPOTIFY_TENSE_PLAYLIST_URL=

# Original Audio Features mode:
SPOTIFY_PLAYLIST_URL=

VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/

# Preferred real-music catalog path:
# Create a free developer app at https://devportal.jamendo.com/.
JAMENDO_CLIENT_ID=
JAMENDO_MAX_TRACKS=100
JAMENDO_REQUIRE_DOWNLOAD_ALLOWED=true

# Optional: comma- or space-separated discovery tags prepended to the default
# search plan. The script still filters for vocalinstrumental=instrumental.
JAMENDO_DISCOVERY_TAGS=

# Optional: save allowed MP3 downloads locally for audit/offline inspection.
# These audio files are ignored by git.
JAMENDO_DOWNLOAD_AUDIO=false
JAMENDO_AUDIO_DIR=data/audio/jamendo
