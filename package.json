{
  "name": "vibe-shuffle",
  "version": "0.1.0",
  "description": "Mood-adaptive music validation dashboard comparing Random Shuffle and Vibe Shuffle.",
  "license": "MIT",
  "homepage": "https://eybmits.github.io/vibe_shuffle_site/",
  "repository": {
    "type": "git",
    "url": "https://github.com/eybmits/vibe_shuffle.git"
  },
  "bugs": {
    "url": "https://github.com/eybmits/vibe_shuffle/issues"
  },
  "keywords": [
    "music-recommendation",
    "affective-computing",
    "spotify",
    "react",
    "validation-study"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "jamendo:catalog": "node scripts/build_jamendo_catalog.mjs",
    "spotify:catalog": "node scripts/build_spotify_catalog.mjs",
    "check:catalog-script": "node --check scripts/build_spotify_catalog.mjs && node --check scripts/build_jamendo_catalog.mjs",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.1.0"
  }
}
